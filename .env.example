# ════════════════════════════════════════════════════════
#  OpenClaw Homelab — environment template
#  Copy this file to `.env` and fill in your own values.
#  NEVER commit your real `.env` to git (it is gitignored).
# ════════════════════════════════════════════════════════

# ── Container image ─────────────────────────────────────
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# ── Host paths (where config + workspace are stored) ────
# Use absolute paths. These directories must be owned by
# UID 1000 (the `node` user inside the container):
#   sudo chown -R 1000:1000 <path>
OPENCLAW_CONFIG_DIR=/home/youruser/openclaw/config
OPENCLAW_WORKSPACE_DIR=/home/youruser/openclaw/workspace

# ── Gateway ─────────────────────────────────────────────
# Generate a token with:  openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token
# "lan" exposes the dashboard to your local network.
# "loopback" restricts it to the host only.
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_TZ=UTC

# ════════════════════════════════════════════════════════
#  LLM PROVIDER  (the "brain" — set exactly ONE)
#  This is REQUIRED. Without it the agent cannot think.
# ════════════════════════════════════════════════════════
# Anthropic Claude   → https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
#
# OpenAI             → https://platform.openai.com
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
#
# Google Gemini      → https://aistudio.google.com  (free tier)
# GEMINI_API_KEY=xxxxxxxxxxxxxxxx
#
# OpenRouter         → https://openrouter.ai  (one key, many models)
# OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════
#  WEB SEARCH  (optional but recommended)
#  Lets the agent look things up online instead of relying
#  only on the LLM's training data.
# ════════════════════════════════════════════════════════
# Brave Search API   → https://brave.com/search/api
# BRAVE_API_KEY=BSAxxxxxxxxxxxxxxxx

# ════════════════════════════════════════════════════════
#  INFRASTRUCTURE CREDENTIALS  (used by skills)
#  Fill in only the ones you actually use.
# ════════════════════════════════════════════════════════

# ── Proxmox VE (virtualization host) ──
# API token: Datacenter > Permissions > API Tokens > Add
# PVE_URL=https://192.168.1.XXX:8006
# PVE_TOKEN=openclaw@pam!homelab=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── TrueNAS (file server) ──
# API key: Settings > API Keys > Add
# TRUENAS_URL=https://192.168.1.XXX
# TRUENAS_API_KEY=xxxxxxxxxxxxxxxx

# ── Pi-hole (filtering DNS) ──
# App password: Settings > API > App Password
# PIHOLE_API_URL=http://192.168.1.XXX/api
# PIHOLE_API_TOKEN=xxxxxxxxxxxxxxxx
# PIHOLE_INSECURE=false

# ── SSH (for running shell commands on remote machines) ──
# Generate a dedicated key:  ssh-keygen -t ed25519 -f ~/.ssh/openclaw_key
SSH_KEY_PATH=/home/youruser/.ssh/openclaw_key
SSH_PUB_PATH=/home/youruser/.ssh/openclaw_key.pub

# ── Docker socket GID (only if you enable the sandbox) ──
# Find it with:  stat -c '%g' /var/run/docker.sock
# DOCKER_GID=999
